{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Visualizer Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runs"
  ],
  "properties": {
    "runs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/runSummary"
      }
    }
  },
  "definitions": {
    "downloads": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "json": {
          "type": "string"
        },
        "csv": {
          "type": "string"
        },
        "xlsx": {
          "type": "string"
        }
      }
    },
    "runSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "created_at",
        "asset_count",
        "enumeration_count",
        "seed_count",
        "data_path"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "asset_count": {
          "type": "integer"
        },
        "enumeration_count": {
          "type": "integer"
        },
        "seed_count": {
          "type": "integer"
        },
        "data_path": {
          "type": "string"
        },
        "downloads": {
          "$ref": "#/definitions/downloads"
        }
      }
    }
  }
}
